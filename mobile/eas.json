{
  "cli": {
    "version": ">= 2.0.0"
  },
  "build": {
    "production": {
      "releaseChannel": "production",
      "npmClient": "npm",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bibleai-i4vr.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "npmClient": "npm",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bibleai-i4vr.onrender.com"
      }
    }
  }
}
