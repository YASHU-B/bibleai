{
  "expo": {
    "name": "Bible Ai",
    "slug": "bible-ai-telugu",
    "owner": "yashu03",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bibleai",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "data/*",
      "assets/audio/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bibleai.app"
    },
    "updates": {
      "url": "https://u.expo.dev/b7f01295-3750-4e88-bb48-9d5883aefa63"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "package": "com.bibleai.app",
      "adaptiveIcon": {
        "backgroundColor": "#090d16",
        "foregroundImage": "./assets/images/icon.png"
      },
      "permissions": [
        "INTERNET"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b7f01295-3750-4e88-bb48-9d5883aefa63"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#090d16",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}